# OpenAI-compatible chat endpoint base, e.g. https://api.x.ai/v1 (Grok) or https://api.aimlapi.com/v1 (AI/ML API)
LLM_BASE_URL=
# API key for the provider above
LLM_API_KEY=
# Model name exactly as the provider's dashboard names it
LLM_MODEL=
# Optional stronger model used for supervisor/panel/planner calls
LLM_MODEL_HEAVY=
# Optional fallback provider (all three must be set to activate), e.g. https://api.x.ai/v1 or https://api.aimlapi.com/v1
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=

# Optional — get one free at semanticscholar.org/product/api; avoids shared-pool 429s
SEMANTIC_SCHOLAR_API_KEY=

# Free at resend.com, 3000 emails/mo
RESEND_API_KEY=
# Without a verified domain, Resend only delivers to the email your Resend account is registered with — fine for the demo
RESEND_FROM_ADDRESS=ResearchOS <onboarding@resend.dev>

# Origin allowed to call this API in production (CORS)
FRONTEND_URL=http://localhost:4028

PORT=4029
